---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  getExcerpt,
  getLengthTypeLabel,
  isSeriesLengthType,
  loadVersions,
} from '../lib/content';

const versions = loadVersions();
const recommended = versions.slice(0, 6);
const recommendedPayload = versions.map((version) => ({
  id: version.id,
  title: version.title,
  ageRange: version.ageRange,
  lengthType: version.lengthType,
  lengthLabel: getLengthTypeLabel(version.lengthType),
  isSeries: isSeriesLengthType(version.lengthType),
  tags: version.tags,
  excerpt: getExcerpt(version, 90),
  chaptersCount: version.chapters?.length ?? 0,
}));
---

<BaseLayout title="Little Y Storybook">
  <section class="hero">
    <div class="section-header">
      <h2>오늘의 이야기</h2>
      <p>잠들기 전, 마음이 포근해지는 시간</p>
    </div>

    <form class="search-bar" action="/stories" method="get">
      <input
        type="search"
        name="q"
        placeholder="어떤 이야기를 찾고 있나요?"
        aria-label="이야기 검색"
      />
      <button class="button" type="submit">검색</button>
    </form>

    <div class="recent-panel">
      <div class="recent-header">
        <h3>최근 읽은 이야기</h3>
        <a class="button secondary" href="/history">읽기 기록 보기</a>
      </div>
      <div class="card-grid compact" data-recent-list>
        <div class="card" data-recent-empty>
          <h3>최근 읽은 이야기가 없어요</h3>
          <p>먼저 한 편을 골라 읽어볼까요?</p>
          <a class="button" href="/stories">전체 이야기 보러가기</a>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="section-header">
      <h2>추천 이야기</h2>
      <p>따뜻한 이야기로 하루를 마무리해요.</p>
    </div>
    <div class="card-grid" data-recommended-grid>
      {recommended.map((version) => {
        const visibleTags = version.tags.slice(0, 4);
        const hiddenTags = version.tags.slice(4);
        const chaptersCount = version.chapters?.length ?? 0;
        const showChapters = isSeriesLengthType(version.lengthType) && chaptersCount > 0;
        return (
          <article class="card">
            <h3>{version.title}</h3>
            <p>{getExcerpt(version, 90)}</p>
            <div class="meta">
              <span class="badge">{version.ageRange}세</span>
              <span class="badge">{getLengthTypeLabel(version.lengthType)}</span>
              {showChapters && <span class="badge">총 {chaptersCount}화</span>}
            </div>
            <div
              class="tag-list"
              data-tag-list={hiddenTags.length ? 'true' : undefined}
              data-expanded={hiddenTags.length ? 'false' : undefined}
            >
              {visibleTags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
              {hiddenTags.map((tag) => (
                <span class="tag is-hidden">{tag}</span>
              ))}
              {hiddenTags.length > 0 && (
                <button
                  class="tag more"
                  type="button"
                  data-tag-toggle
                  data-more-count={hiddenTags.length}
                  aria-expanded="false"
                >
                  +{hiddenTags.length}
                </button>
              )}
            </div>
            <a class="button" href={`/read/${version.id}`}>읽기</a>
          </article>
        );
      })}
    </div>
    <script
      type="application/json"
      data-recommended-source
      set:html={JSON.stringify(recommendedPayload).replace(/</g, '\\u003c')}
    ></script>
  </section>

  <section>
    <div class="section-header">
      <h2>빠른 필터</h2>
      <p>아이 나이와 길이에 맞게 선택하세요.</p>
    </div>
    <div class="chip-row is-scroll">
      <a class="chip" href="/stories">전체</a>
      <a class="chip" href="/stories?age=3-5">3-5세</a>
      <a class="chip" href="/stories?age=6-7">6-7세</a>
      <a class="chip" href="/stories?age=8-9">8-9세</a>
      <a class="chip" href="/stories?length=short">짧음</a>
      <a class="chip" href="/stories?length=medium">보통</a>
      <a class="chip" href="/stories?length=long">김</a>
      <a class="chip" href="/stories?length=short_series">짧은 연작</a>
      <a class="chip" href="/stories?length=long_series">긴 연작</a>
    </div>
  </section>

  <script is:inline>
    const SERIES_LENGTH_TYPES = ['series', 'short_series', 'long_series'];
    const LENGTH_TYPE_LABELS = {
      short: '짧음',
      medium: '보통',
      long: '김',
      series: '연작',
      short_series: '짧은 연작',
      long_series: '긴 연작',
    };
    const isSeriesLengthType = (lengthType) => SERIES_LENGTH_TYPES.includes(lengthType);
    const getLengthTypeLabel = (lengthType) => LENGTH_TYPE_LABELS[lengthType] || lengthType;

    const recentContainer = document.querySelector('[data-recent-list]');
    const emptyState = document.querySelector('[data-recent-empty]');

    const raw = localStorage.getItem('storybook:recent');
    const recent = raw ? JSON.parse(raw) : [];

    if (recent.length && recentContainer) {
      recentContainer.innerHTML = '';
      recent.slice(0, 1).forEach((item) => {
        const chapterHash =
          isSeriesLengthType(item.length_type) && item.last_chapter_index
            ? `#chapter-${item.last_chapter_index}`
            : '';
        const card = document.createElement('article');
        card.className = 'mini-card recent-card';
        const lengthLabel = getLengthTypeLabel(item.length_type);
        card.innerHTML = `
          <div class="recent-info">
            <h3>${item.title}</h3>
            <p>${isSeriesLengthType(item.length_type) ? `마지막으로 읽은 회차: ${item.last_chapter_index ?? 1}화` : '단편 이야기'}</p>
            <div class="meta">
              <span class="badge">${item.age_range}세</span>
              <span class="badge">${lengthLabel}</span>
            </div>
          </div>
          <a class="button" href="/read/${item.id}${chapterHash}">이어보기</a>
        `;
        recentContainer.appendChild(card);
      });
    } else if (emptyState) {
      emptyState.style.display = 'block';
    }

    const recommendedGrid = document.querySelector('[data-recommended-grid]');
    const recommendedSource = document.querySelector('[data-recommended-source]');
    if (recommendedGrid && recommendedSource?.textContent) {
      try {
        const raw = JSON.parse(recommendedSource.textContent);
        if (Array.isArray(raw) && raw.length) {
          const shuffled = raw
            .map((item) => ({ item, sort: Math.random() }))
            .sort((a, b) => a.sort - b.sort)
            .map(({ item }) => item);
          const picks = shuffled.slice(0, 6);
          recommendedGrid.innerHTML = '';

          const createTagList = (tags = []) => {
            const tagList = document.createElement('div');
            tagList.className = 'tag-list';
            const visible = tags.slice(0, 4);
            const hidden = tags.slice(4);
            if (hidden.length) {
              tagList.dataset.tagList = 'true';
              tagList.dataset.expanded = 'false';
            }
            visible.forEach((tag) => {
              const span = document.createElement('span');
              span.className = 'tag';
              span.textContent = tag;
              tagList.appendChild(span);
            });
            hidden.forEach((tag) => {
              const span = document.createElement('span');
              span.className = 'tag is-hidden';
              span.textContent = tag;
              tagList.appendChild(span);
            });
            if (hidden.length) {
              const button = document.createElement('button');
              button.type = 'button';
              button.className = 'tag more';
              button.dataset.tagToggle = 'true';
              button.dataset.moreCount = String(hidden.length);
              button.setAttribute('aria-expanded', 'false');
              button.textContent = `+${hidden.length}`;
              tagList.appendChild(button);
            }
            return tagList;
          };

          picks.forEach((version) => {
            const article = document.createElement('article');
            article.className = 'card';

            const title = document.createElement('h3');
            title.textContent = version.title;

            const excerpt = document.createElement('p');
            excerpt.textContent = version.excerpt;

            const meta = document.createElement('div');
            meta.className = 'meta';
            const age = document.createElement('span');
            age.className = 'badge';
            age.textContent = `${version.ageRange}세`;
            const length = document.createElement('span');
            length.className = 'badge';
            length.textContent = version.lengthLabel;
            meta.appendChild(age);
            meta.appendChild(length);
            if (version.isSeries && version.chaptersCount) {
              const chapters = document.createElement('span');
              chapters.className = 'badge';
              chapters.textContent = `총 ${version.chaptersCount}화`;
              meta.appendChild(chapters);
            }

            const tagList = createTagList(version.tags);

            const link = document.createElement('a');
            link.className = 'button';
            link.href = `/read/${version.id}`;
            link.textContent = '읽기';

            article.appendChild(title);
            article.appendChild(excerpt);
            article.appendChild(meta);
            article.appendChild(tagList);
            article.appendChild(link);

            recommendedGrid.appendChild(article);
          });
        }
      } catch (error) {
        console.warn('추천 이야기를 불러오는 중 문제가 발생했습니다.', error);
      }
    }
  </script>
</BaseLayout>
