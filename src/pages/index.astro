---
import BaseLayout from '../layouts/BaseLayout.astro';
import { loadVersions, getExcerpt } from '../lib/content';

const versions = loadVersions();
const recommended = versions.slice(0, 6);
---

<BaseLayout title="Little Y Storybook">
  <section class="hero">
    <div class="section-header">
      <h2>오늘의 이야기</h2>
      <p>잠들기 전, 마음이 포근해지는 시간</p>
    </div>

    <form class="search-bar" action="/stories" method="get">
      <input
        type="search"
        name="q"
        placeholder="어떤 이야기를 찾고 있나요?"
        aria-label="이야기 검색"
      />
      <button class="button" type="submit">검색</button>
    </form>

    <div class="card-grid" data-recent-list>
      <div class="card" data-recent-empty>
        <h3>최근 읽은 이야기가 없어요</h3>
        <p>먼저 한 편을 골라 읽어볼까요?</p>
        <a class="button" href="/stories">전체 이야기 보러가기</a>
      </div>
    </div>
  </section>

  <section>
    <div class="section-header">
      <h2>추천 이야기</h2>
      <p>따뜻한 이야기로 하루를 마무리해요.</p>
    </div>
    <div class="card-grid">
      {recommended.map((version) => (
        <article class="card">
          <h3>{version.title}</h3>
          <p>{getExcerpt(version, 90)}</p>
          <div class="meta">
            <span class="badge">{version.ageRange}세</span>
            <span class="badge">{version.lengthType}</span>
          </div>
          <div class="tag-list">
            {version.tags.slice(0, 3).map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
          <a class="button" href={`/stories/${version.id}`}>자세히 보기</a>
        </article>
      ))}
    </div>
  </section>

  <section>
    <div class="section-header">
      <h2>빠른 필터</h2>
      <p>아이 나이와 길이에 맞게 선택하세요.</p>
    </div>
    <div class="chip-row is-scroll">
      <a class="chip" href="/stories">전체</a>
      <a class="chip" href="/stories?age=3-5">3-5세</a>
      <a class="chip" href="/stories?age=6-7">6-7세</a>
      <a class="chip" href="/stories?age=8-9">8-9세</a>
      <a class="chip" href="/stories?length=short">짧음</a>
      <a class="chip" href="/stories?length=medium">보통</a>
      <a class="chip" href="/stories?length=long">김</a>
      <a class="chip" href="/stories?length=series">연작</a>
    </div>
  </section>

  <script is:inline>
    const recentContainer = document.querySelector('[data-recent-list]');
    const emptyState = document.querySelector('[data-recent-empty]');

    const raw = localStorage.getItem('storybook:recent');
    const recent = raw ? JSON.parse(raw) : [];

    if (recent.length && recentContainer) {
      recentContainer.innerHTML = '';
      recent.slice(0, 5).forEach((item) => {
        const chapterHash =
          item.length_type === 'series' && item.last_chapter_index
            ? `#chapter-${item.last_chapter_index}`
            : '';
        const card = document.createElement('article');
        card.className = 'card';
        card.innerHTML = `
          <h3>${item.title}</h3>
          <p>${item.length_type === 'series' ? `마지막으로 읽은 회차: ${item.last_chapter_index ?? 1}화` : '단편 이야기'}</p>
          <div class="meta">
            <span class="badge">${item.age_range}세</span>
            <span class="badge">${item.length_type}</span>
          </div>
          <a class="button" href="/read/${item.id}${chapterHash}">이어보기</a>
        `;
        recentContainer.appendChild(card);
      });
    } else if (emptyState) {
      emptyState.style.display = 'block';
    }
  </script>
</BaseLayout>
