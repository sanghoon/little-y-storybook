---
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  getExcerpt,
  getLengthTypeLabel,
  isSeriesLengthType,
  loadVersions,
} from '../../lib/content';

const DEFAULT_SORT = 'updated-desc';
type SortValue = 'updated-desc' | 'updated-asc' | 'title-asc' | 'title-desc';
type StoryVersion = ReturnType<typeof loadVersions>[number] & {
  updatedAt: string;
  updatedAtMs: number;
};

const sortVersions = (items: StoryVersion[], sort: SortValue): StoryVersion[] => {
  const versions = [...items];
  if (sort === 'updated-asc') {
    return versions.sort((a, b) => a.updatedAtMs - b.updatedAtMs);
  }
  if (sort === 'title-asc') {
    return versions.sort(
      (a, b) =>
        a.title.localeCompare(b.title, 'ko') || b.updatedAtMs - a.updatedAtMs
    );
  }
  if (sort === 'title-desc') {
    return versions.sort(
      (a, b) =>
        b.title.localeCompare(a.title, 'ko') || b.updatedAtMs - a.updatedAtMs
    );
  }
  return versions.sort((a, b) => b.updatedAtMs - a.updatedAtMs);
};

const formatUpdatedDate = (value: string): string => {
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '';
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
};

const sortOptions = [
  { value: 'updated-desc', label: '최신 업데이트순' },
  { value: 'updated-asc', label: '오래된 업데이트순' },
  { value: 'title-asc', label: '제목 가나다순' },
  { value: 'title-desc', label: '제목 역순' },
] satisfies Array<{ value: SortValue; label: string }>;

const versions = sortVersions(loadVersions() as StoryVersion[], DEFAULT_SORT);
const ages = ['3-5', '6-7', '8-9'];
const lengths = ['short', 'medium', 'long', 'short_series', 'long_series'] as const;
const tags = Array.from(
  new Set(versions.flatMap((version) => version.tags))
).slice(0, 12);
---

<BaseLayout title="전체 이야기">
  <section>
    <div class="section-header">
      <h2>전체 이야기</h2>
      <p data-count>{versions.length}개의 이야기가 준비되어 있어요.</p>
    </div>

    <div class="search-bar">
      <input type="search" placeholder="제목이나 키워드를 입력하세요" data-search />
      <label class="sort-control">
        정렬
        <select data-sort>
          {sortOptions.map((option: { value: SortValue; label: string }) => (
            <option value={option.value}>{option.label}</option>
          ))}
        </select>
      </label>
      <button class="button secondary" type="button" data-reset>초기화</button>
    </div>

    <div class="chip-row is-scroll" data-filter-group="age">
      <button class="chip is-active" data-filter-value="" type="button">전체 연령</button>
      {ages.map((age) => (
        <button
          class="chip"
          data-filter-value={age}
          type="button"
          aria-label={`${age}세 연령`}
        >
          {age}세
        </button>
      ))}
    </div>

    <div class="chip-row is-scroll" data-filter-group="length">
      <button class="chip is-active" data-filter-value="" type="button">전체 길이</button>
      {lengths.map((length) => (
        <button
          class="chip"
          data-filter-value={length}
          type="button"
          aria-label={`${getLengthTypeLabel(length)} 길이`}
        >
          {getLengthTypeLabel(length)}
        </button>
      ))}
    </div>

    <div class="chip-row is-scroll" data-filter-group="tag">
      <button class="chip is-active" data-filter-value="" type="button">전체 태그</button>
      {tags.map((tag: string) => (
        <button
          class="chip"
          data-filter-value={tag}
          type="button"
          aria-label={`${tag} 태그`}
        >
          {tag}
        </button>
      ))}
    </div>
  </section>

  <section>
    <div class="card-grid" data-card-grid>
      {versions.map((version) => {
        const visibleTags = version.tags.slice(0, 4);
        const hiddenTags = version.tags.slice(4);
        const chaptersCount = version.chapters?.length ?? 0;
        const showChapters = isSeriesLengthType(version.lengthType) && chaptersCount > 0;
        return (
          <article
            class="card"
            data-age={version.ageRange}
            data-length={version.lengthType}
            data-tags={version.tags.join(',')}
            data-title={version.title}
            data-summary={version.summary}
            data-updated-at-ms={String(version.updatedAtMs)}
          >
            <h3>{version.title}</h3>
            <p>{getExcerpt(version, 100)}</p>
            <p class="card-date">업데이트 {formatUpdatedDate(version.updatedAt)}</p>
            <div class="meta">
              <span class="badge">{version.ageRange}세</span>
              <span class="badge">{getLengthTypeLabel(version.lengthType)}</span>
              {showChapters && <span class="badge">총 {chaptersCount}화</span>}
            </div>
            <div
              class="tag-list"
              data-tag-list={hiddenTags.length ? 'true' : undefined}
              data-expanded={hiddenTags.length ? 'false' : undefined}
            >
              {visibleTags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
              {hiddenTags.map((tag) => (
                <span class="tag is-hidden">{tag}</span>
              ))}
              {hiddenTags.length > 0 && (
                <button
                  class="tag more"
                  type="button"
                  data-tag-toggle
                  data-more-count={hiddenTags.length}
                  aria-expanded="false"
                >
                  +{hiddenTags.length}
                </button>
              )}
            </div>
            <a class="button" href={`/read/${version.id}`}>읽기</a>
          </article>
        );
      })}
    </div>
    <div class="card empty-state" data-empty>
      <h3>조건에 맞는 이야기가 없어요</h3>
      <p>필터를 초기화하거나 다른 태그를 선택해보세요.</p>
      <button class="button" type="button" data-reset>필터 초기화</button>
    </div>
  </section>

  <script is:inline>
    const SERIES_LENGTH_TYPES = ['series', 'short_series', 'long_series'];
    const SORT_VALUES = ['updated-desc', 'updated-asc', 'title-asc', 'title-desc'];
    const DEFAULT_SORT = 'updated-desc';
    const isSeriesLengthType = (length) => SERIES_LENGTH_TYPES.includes(length);
    const state = { age: '', length: '', tag: '', query: '', sort: DEFAULT_SORT };
    const countEl = document.querySelector('[data-count]');
    const emptyEl = document.querySelector('[data-empty]');
    const searchInput = document.querySelector('[data-search]');
    const sortSelect = document.querySelector('[data-sort]');
    const grid = document.querySelector('[data-card-grid]');
    const resetButtons = document.querySelectorAll('[data-reset]');

    const params = new URLSearchParams(window.location.search);
    state.age = params.get('age') || '';
    state.length = params.get('length') || '';
    state.tag = params.get('tag') || '';
    state.query = params.get('q') || '';
    state.sort = SORT_VALUES.includes(params.get('sort')) ? params.get('sort') : DEFAULT_SORT;

    if (searchInput) searchInput.value = state.query;
    if (sortSelect) sortSelect.value = state.sort;

    const syncButtons = () => {
      document.querySelectorAll('[data-filter-group]').forEach((group) => {
        const groupName = group.dataset.filterGroup;
        const value = state[groupName] || '';
        group.querySelectorAll('button').forEach((button) => {
          button.classList.toggle(
            'is-active',
            (button.dataset.filterValue || '') === value
          );
        });
      });
    };

    const updateUrl = () => {
      const next = new URLSearchParams();
      if (state.age) next.set('age', state.age);
      if (state.length) next.set('length', state.length);
      if (state.tag) next.set('tag', state.tag);
      if (state.query) next.set('q', state.query);
      if (state.sort && state.sort !== DEFAULT_SORT) next.set('sort', state.sort);
      const nextUrl = `${window.location.pathname}${next.toString() ? `?${next}` : ''}`;
      window.history.replaceState({}, '', nextUrl);
    };

    const compareCards = (left, right) => {
      const leftTitle = left.dataset.title || '';
      const rightTitle = right.dataset.title || '';
      const leftUpdatedAt = Number(left.dataset.updatedAtMs || 0);
      const rightUpdatedAt = Number(right.dataset.updatedAtMs || 0);

      if (state.sort === 'updated-asc') {
        return leftUpdatedAt - rightUpdatedAt;
      }

      if (state.sort === 'title-asc') {
        return leftTitle.localeCompare(rightTitle, 'ko') || rightUpdatedAt - leftUpdatedAt;
      }

      if (state.sort === 'title-desc') {
        return rightTitle.localeCompare(leftTitle, 'ko') || rightUpdatedAt - leftUpdatedAt;
      }

      return rightUpdatedAt - leftUpdatedAt;
    };

    const sortCards = (cards) => {
      if (!grid) return;
      cards
        .slice()
        .sort(compareCards)
        .forEach((card) => {
          grid.appendChild(card);
        });
    };

    const updateCards = () => {
      const cards = Array.from(document.querySelectorAll('[data-card-grid] .card'));
      sortCards(cards);
      let count = 0;
      cards.forEach((card) => {
        const age = card.dataset.age || '';
        const length = card.dataset.length || '';
        const tags = card.dataset.tags || '';
        const title = card.dataset.title || '';
        const summary = card.dataset.summary || '';

        const matchAge = !state.age || age === state.age;
        const matchLength = !state.length
          || (state.length === 'series' ? isSeriesLengthType(length) : length === state.length);
        const matchTag = !state.tag || tags.includes(state.tag);
        const queryTarget = `${title} ${summary} ${tags}`.toLowerCase();
        const matchQuery =
          !state.query || queryTarget.includes(state.query.toLowerCase());

        const visible = matchAge && matchLength && matchTag && matchQuery;
        card.style.display = visible ? 'flex' : 'none';
        if (visible) count += 1;
      });

      if (countEl) {
        countEl.textContent = `${count}개의 이야기가 준비되어 있어요.`;
      }

      if (emptyEl) {
        emptyEl.classList.toggle('is-visible', count === 0);
      }
    };

    document.querySelectorAll('[data-filter-group]').forEach((group) => {
      group.addEventListener('click', (event) => {
        const target = event.target.closest('button');
        if (!target) return;
        const value = target.dataset.filterValue || '';
        const groupName = group.dataset.filterGroup;
        state[groupName] = value;
        syncButtons();
        updateUrl();
        updateCards();
      });
    });

    if (searchInput) {
      searchInput.addEventListener('input', (event) => {
        state.query = event.target.value.trim();
        updateUrl();
        updateCards();
      });
    }

    if (sortSelect) {
      sortSelect.addEventListener('change', (event) => {
        const next = event.target.value;
        state.sort = SORT_VALUES.includes(next) ? next : DEFAULT_SORT;
        updateUrl();
        updateCards();
      });
    }

    resetButtons.forEach((button) => {
      button.addEventListener('click', () => {
        state.age = '';
        state.length = '';
        state.tag = '';
        state.query = '';
        state.sort = DEFAULT_SORT;
        if (searchInput) searchInput.value = '';
        if (sortSelect) sortSelect.value = DEFAULT_SORT;
        syncButtons();
        updateUrl();
        updateCards();
      });
    });

    syncButtons();
    updateCards();
  </script>
</BaseLayout>
