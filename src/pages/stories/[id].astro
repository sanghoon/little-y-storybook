---
import { loadVersions } from '../../lib/content';

export function getStaticPaths() {
  const versions = loadVersions();
  return versions.map((version) => ({ params: { id: version.id } }));
}

const { id } = Astro.params;
const versions = loadVersions();
const exists = versions.some((version) => version.id === id);

if (!exists) {
  return Astro.redirect('/stories');
}

return Astro.redirect(`/read/${id}`);
---

